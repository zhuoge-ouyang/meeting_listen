# RecordWise Backend Configuration — SAMPLE
#
# Copy this file to ".env" in the same directory and fill in the values
# below.  The real ".env" file is git-ignored so secrets stay on your
# machine only.
#
#   cp recordwise_backend/.env_sample recordwise_backend/.env
#
APP_NAME=RecordWise
APP_VERSION=2.0.0
DEBUG=True

# API Security
# Bearer token clients must send when REQUIRE_AUTH=true. Generate a long
# random string for production (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`).
API_TOKEN=<your-api-token>
REQUIRE_AUTH=false

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Aliyun / DashScope Configuration
DASHSCOPE_API_KEY=<your-dashscope-api-key>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_ASR_MODEL=fun-asr
QWEN_SUMMARY_MODEL=qwen-plus
QWEN_MT_MODEL=qwen-mt-flash
QWEN_TTS_MODEL=qwen3-tts-flash

# Aliyun OSS. DashScope recorded-file ASR needs a public or signed HTTP URL.
ALIYUN_ACCESS_KEY_ID=<your-aliyun-access-key-id>
ALIYUN_ACCESS_KEY_SECRET=<your-aliyun-access-key-secret>
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=<your-oss-bucket>
# Optional if your bucket is public/CDN-backed. Leave blank to use signed URLs.
# ALIYUN_OSS_PUBLIC_BASE_URL=https://<bucket>.oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_SIGNED_URL_EXPIRE_SECONDS=3600

TTS_AUDIO_CACHE_DIR=storage/tts
